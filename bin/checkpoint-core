#!/usr/bin/env python3
"""Standalone launcher for Checkpoint Core (no install needed).

Add this directory to PATH, or symlink onto your PATH:
    ln -s "$(pwd)/bin/checkpoint-core" /usr/local/bin/checkpoint-core
"""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from checkpoint_core.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
