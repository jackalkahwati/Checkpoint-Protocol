#!/usr/bin/env python3
"""Standalone launcher for the Checkpoint hosted API (no install needed)."""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from checkpoint_core.server.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
